{
  "name": "Caradance 扒舞助手",
  "description": "B站/抖音网页扒舞插件，支持打点、A/B 点、跳段、变速、循环和历史片段。",
  "version": "0.2.0",
  "manifest_version": 3,
  "action": {
    "default_title": "Caradance 扒舞助手",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://*.douyin.com/*",
    "*://*.iesdouyin.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.bilibili.com/*",
        "*://*.douyin.com/*",
        "*://*.iesdouyin.com/*"
      ],
      "js": [
        "content-script/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "faster": {
      "suggested_key": {
        "default": "Ctrl+Shift+Up",
        "mac": "Command+Shift+Up"
      },
      "description": "提高播放速度"
    },
    "slower": {
      "suggested_key": {
        "default": "Ctrl+Shift+Down",
        "mac": "Command+Shift+Down"
      },
      "description": "降低播放速度"
    },
    "previous-marker": {
      "suggested_key": {
        "default": "Alt+Shift+Up",
        "mac": "Option+Shift+Up"
      },
      "description": "跳到上一个打点"
    },
    "next-marker": {
      "suggested_key": {
        "default": "Alt+Shift+Down",
        "mac": "Option+Shift+Down"
      },
      "description": "跳到下一个打点"
    }
  }
}
