{
  "name": "Hello World Extension",
  "description": "A minimal Manifest V3 Chrome extension for local development.",
  "version": "0.1.0",
  "manifest_version": 3,
  "action": {
    "default_title": "Hello World",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
